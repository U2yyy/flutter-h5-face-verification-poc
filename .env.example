# Copy this file to `.env` and fill in your Tencent Cloud credentials.
# Get SecretId/SecretKey: https://console.cloud.tencent.com/cam/capi

TENCENT_SECRET_ID=your_secret_id_here
TENCENT_SECRET_KEY=your_secret_key_here

# Region for FaceID (1061). CompareFaceLiveness intl supports:
# ap-singapore, ap-hongkong, ap-bangkok
TENCENT_REGION=ap-singapore

# FaceID API host (product 1061 — 活体人脸核身)
# International: faceid.intl.tencentcloudapi.com
# Domestic (China): faceid.tencentcloudapi.com
TENCENT_FACEID_HOST=faceid.intl.tencentcloudapi.com

# Pure-API liveness type: SILENT or ACTION
TENCENT_FACEID_LIVENESS_TYPE=SILENT

# Required when LIVENESS_TYPE=ACTION (intl CompareFaceLiveness).
# 1=open mouth, 2=blink, 3=nod, 4=shake head. Example: 2 or 4,2
TENCENT_FACEID_VALIDATE_DATA=

# SaaS SDK flow (GetFaceIdTokenIntl): secure level 1–4, default 4
TENCENT_FACEID_SECURE_LEVEL=4

# SaaS SDK version: BASIC, ENHANCED, PRO, PLUS
TENCENT_FACEID_SDK_VERSION=BASIC

# Optional RuleId for domestic GetFaceIdToken / H5 ApplyWebVerification
TENCENT_FACEID_RULE_ID=

# H5 liveness (ApplyWebVerificationBizTokenIntl)
# Tencent redirects here after liveness with ?token={BizToken}. Use any HTTPS
# URL; the app intercepts navigation in WebView (no real server required).
TENCENT_FACEID_H5_REDIRECT_URL=https://facedetection.local/liveness/callback

# When true, skip Tencent H5 result page and auto-redirect (Config.AutoSkip)
TENCENT_FACEID_H5_AUTO_SKIP=false

# --- Baidu AI Face Verification (Pure API) ---
# Create an app: https://console.bce.baidu.com/ai/#/ai/face/overview/index
BAIDU_API_KEY=your_api_key_here
BAIDU_SECRET_KEY=your_secret_key_here

# Face 1:1 match pass threshold (Baidu recommends 80)
BAIDU_MATCH_THRESHOLD=80

# Video liveness threshold key from API response: frr_1e-4, frr_1e-3, frr_1e-2
BAIDU_LIVENESS_THRESHOLD_KEY=frr_1e-3

# Liveness/quality control for live image in match: NONE, LOW, NORMAL, HIGH
BAIDU_LIVENESS_CONTROL=NORMAL
BAIDU_QUALITY_CONTROL=NORMAL

# --- Baidu faceprint H5 (SaaS H5 flow) ---
# Create four H5 plans (与上传照片比对) — one per liveness method.
# Defaults match common console IDs; override if yours differ.
BAIDU_FACEPRINT_PLAN_ID_DAZZLE=26109
BAIDU_FACEPRINT_PLAN_ID_NEAR_FAR=26110
BAIDU_FACEPRINT_PLAN_ID_ACTION=26111
BAIDU_FACEPRINT_PLAN_ID_SILENT=26112

# Redirect base for WebView callback detection (?token=verify_token appended by app).
BAIDU_FACEPRINT_H5_CALLBACK_URL=https://facedetection.local/baidu/h5/callback

# --- Aliyun CloudAuth PV_FV H5 (financial-grade liveness + face contrast) ---
# RAM user with AliyunAntCloudAuthFullAccess. Create SceneId in CloudAuth console.
ALIYUN_ACCESS_KEY_ID=your_access_key_id_here
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret_here
ALIYUN_CLOUDAUTH_SCENE_ID=1000000000
ALIYUN_CLOUDAUTH_REGION_ID=cn-shanghai

# ReturnUrl — Aliyun redirects here with ?response= JSON after liveness completes.
# `.local` is OK for signature debugging; use a public HTTPS URL for real H5 callbacks.
ALIYUN_CLOUDAUTH_RETURN_URL=https://facedetection.local/aliyun/h5/callback

# InitFaceVerify Model: SILENT_LIVENESS, LIVENESS, PHOTINUS_LIVENESS, MULTI_ACTION, MOVE_ACTION, MULTI_PHOTINUS
ALIYUN_CLOUDAUTH_MODEL=MOVE_ACTION
ALIYUN_CLOUDAUTH_CROP=T
ALIYUN_CLOUDAUTH_USER_ID=facedetection-demo-user

# Minimal InitFaceVerify defaults: CertifyUrlType=H5 (see app_config.dart).
# Optional extras — omit for signature debugging (not sent when unset):
# ALIYUN_CLOUDAUTH_CALLBACK_URL=https://www.aliyun.com
# ALIYUN_CLOUDAUTH_VOLUNTARY_CUSTOMIZED_CONTENT=["本人王先生同意***协议。"]
# ALIYUN_CLOUDAUTH_SOURCE_IP=58.48.159.34

# InitFaceVerify face contrast (mutually exclusive — URL or base64, not both).
# Default (no .env entry): base64 FaceContrastPicture from the picked reference photo.
# Optional URL override (skips reference photo in app):
# ALIYUN_CLOUDAUTH_FACE_CONTRAST_PICTURE_URL=https://your-cdn.com/face.jpg

# Optional: static MetaInfo for Explorer-style API testing (skips WebView loader when set).
# ALIYUN_CLOUDAUTH_METAINFO_OVERRIDE={"zimVer":"3.0.0","appVersion":"1","bioMetaInfo":"4.1.0:11501568,0","appName":"com.aliyun.antcloudauth","deviceType":"ios","osVersion":"iOS 10.3.2","apdidToken":"","deviceModel":"iPhone9,1"}

# H5 WebView params — CERTIFY_URL_TYPE defaults to H5; set empty to omit.
# ALIYUN_CLOUDAUTH_CERTIFY_URL_TYPE=H5
# ALIYUN_CLOUDAUTH_CERTIFY_URL_STYLE=S
# ALIYUN_CLOUDAUTH_PROCEDURE_PRIORITY=url

# verifyScore pass threshold from DescribeFaceVerify MaterialInfo
ALIYUN_MATCH_THRESHOLD=70

# Debug: dump FaceContrastPicture base64 to temp .b64 (log includes adb pull path; default off)
# ALIYUN_DEBUG_DUMP_FACE_CONTRAST=true

# Debug: log full local stringToSign in AliyunTrace request JSON (default prefix only)
# ALIYUN_LOG_STRING_TO_SIGN=true

# --- Megvii FinAuth H5 Lite (overseas) ---
# Apply for api_key/api_secret via FinAuth console: https://global.yljz.com/console/login
FINAUTH_API_KEY=your_api_key_here
FINAUTH_API_SECRET=your_api_secret_here

# Overseas API host and DoVerification page base
FINAUTH_API_HOST=api-global.yljz.com
FINAUTH_DO_VERIFICATION_BASE=https://api-global.yljz.com/finauth/lite/do

# return_url — FinAuth redirects here after liveness (GET ?biz_id= for WebView intercept)
FINAUTH_H5_RETURN_URL=https://facedetection.local/finauth/h5/callback

# notify_url — required by get_token (server-side POST; POC uses placeholder HTTPS URL)
FINAUTH_NOTIFY_URL=https://facedetection.local/finauth/notify

# Optional console scene_id (mobile H5 lite theme / flow)
# FINAUTH_SCENE_ID=

# get_token params
FINAUTH_USER_UUID=facedetection-demo-user
FINAUTH_COMPARISON_TYPE=0
FINAUTH_PROCEDURE_TYPE=flash
# FINAUTH_PROCEDURE_PRIORITY=
FINAUTH_LANGUAGE=0
FINAUTH_ACTION_HTTP_METHOD=GET
# FINAUTH_REDIRECT_TYPE=1
FINAUTH_FMP_MODE=0

# Match pass threshold from get_result verify_result.result_ref1.thresholds
FINAUTH_MATCH_THRESHOLD_KEY=1e-4
