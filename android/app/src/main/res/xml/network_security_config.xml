<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- H5 flows load HTTPS CDN (o.alicdn.com) and CertifyUrl; block cleartext. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
